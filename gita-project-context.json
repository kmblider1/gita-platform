  "learning_concepts_for_day_2": {
    "next_js_app_router": "app/ papkada har page.tsx = URL. app/page.tsx=/, app/kurslar/page.tsx=/kurslar. Android'dagi Activity'ga o'xshash.",
    "tsx_vs_html": "HTML: <div class='bg-red'>. TSX: <div className='bg-red'>. Faqat class→className, for→htmlFor. Qolgani bir xil.",
    "tailwind": "CSS yozmaysan — klasslardan foydalanasan. Misol: <button className='bg-teal text-cream px-6 py-3 rounded-lg hover:bg-teal-deep'>",
    "component": "Qayta ishlatiladigan UI bloki. Java class'ga o'xshash. function Button({text}: {text: string}) { return <button>{text}</button> }"
  },

